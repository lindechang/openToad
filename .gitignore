# OpenToad .gitignore

# Database files
*.db

# IDE and editor files
.DS_Store
.vscode/
.idea/

# Python files
__pycache__/
*.pyc

# Environment files
.env
.env.local

# Log files
*.log

# Temporary files
tmp/
temp/

# Runtime configuration and data
config.json
settings.json
history.json
profile.json

# Package build
*.egg-info/
dist/
build/

# Documentation (暂不上传)
docs/