#!/usr/bin/env python3
import sys
import os

PROJECT_ROOT = os.path.abspath(os.path.join(os.path.dirname(__file__)))
if PROJECT_ROOT not in sys.path:
    sys.path.insert(0, PROJECT_ROOT)

from PySide6.QtWidgets import QApplication, QMainWindow, QVBoxLayout, QWidget
from PySide6.QtCore import Qt
from apps.desktop.src.ui.agent_network_panel import AgentNetworkPanel

class TestWindow(QMainWindow):
    def __init__(self):
        super().__init__()
        self.setWindowTitle("OpenToad - Agent Network (Test)")
        self.setMinimumSize(1200, 700)
        
        central = QWidget()
        layout = QVBoxLayout(central)
        layout.setContentsMargins(0, 0, 0, 0)
        
        self.agent_panel = AgentNetworkPanel()
        layout.addWidget(self.agent_panel)
        
        self.setCentralWidget(central)

if __name__ == "__main__":
    app = QApplication(sys.argv)
    app.setStyle("Fusion")
    
    window = TestWindow()
    window.show()
    
    print("✅ Agent Network Panel 已启动！")
    print("📋 功能说明：")
    print("   • 左侧是 Agent 列表（已预置了几个示例 Agent）")
    print("   • 右侧是任务管理区域")
    print("   • 点击「New Task」创建新任务")
    print("   • 选择任务后点击「Split Task」可拆分任务")
    
    sys.exit(app.exec())
